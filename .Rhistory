title = 'condition_DAF_vs_CMAST',
subtitle = 'Volcano plot with LFC shrinkage (apeglm)',
caption = 'FC cutoff = 2; p-value cutoff = 0.05',
legendPosition = 'right',
legendLabSize = 10,
legendIconSize = 3.0,
drawConnectors = TRUE,           # Draws lines from labels to points if crowded
widthConnectors = 0.5,
colConnectors = 'black'
)
pdf("Volcano_Plot_DAF_vs_CMAST.pdf", width = 8, height = 8)
EnhancedVolcano(
toptable = LFC,                  # Can take a DESeqResults object directly
lab = rownames(LFC),             # What to use for gene labels
x = 'log2FoldChange',            # Column name for log2 fold change
y = 'padj',                      # Column name for p-value (it auto-calculates -log10)
